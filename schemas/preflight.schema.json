{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keenetic-debug/schemas/preflight.schema.json",
  "title": "Preflight Report",
  "description": "Результат preflight: capabilities, warnings, estimates, collectors summary.",
  "type": "object",
  "required": ["schema_id", "schema_version", "report_id", "timestamp", "device", "capabilities", "estimates", "collectors_summary"],
  "properties": {
    "schema_id": {"const": "preflight"},
    "schema_version": {"type": "string", "pattern": "^[0-9]+$"},
    "report_id": {"type": "string", "minLength": 10},
    "timestamp": {"type": "string", "format": "date-time"},
    "device": {
      "type": "object",
      "required": ["model", "arch"],
      "properties": {
        "model": {"type": "string"},
        "arch": {"enum": ["mipsel", "mips", "aarch64"]},
        "os_version": {"type": "string"},
        "entware": {"type": "boolean"},
        "storage_type": {"enum": ["internal", "usb", "unknown"]}
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "commands": {"type": "object", "additionalProperties": {"type": "boolean"}},
        "files": {"type": "object", "additionalProperties": {"type": "boolean"}},
        "endpoints": {"type": "object", "additionalProperties": {"type": "boolean"}}
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message_key"],
        "properties": {
          "code": {"type": "string"},
          "message_key": {"type": "string"},
          "params": {"type": "object"}
        }
      }
    },
    "estimates": {
      "type": "object",
      "required": ["total_time_s", "total_size_mb"],
      "properties": {
        "total_time_s": {"type": "number", "minimum": 0},
        "total_size_mb": {"type": "number", "minimum": 0},
        "cpu_peak_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "ram_peak_mb": {"type": "number", "minimum": 0},
        "io_total_mb": {"type": "number", "minimum": 0}
      }
    },
    "collectors_summary": {
      "type": "object",
      "required": ["included", "skipped", "total"],
      "properties": {
        "included": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      }
    }
  }
}
