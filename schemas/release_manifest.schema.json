{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keenetic-debug/schemas/release_manifest.schema.json",
  "title": "Release Manifest",
  "description": "Manifest артефактов релиза с pinned sha256 и версиями.",
  "type": "object",
  "required": ["version", "date", "artifacts"],
  "properties": {
    "version": {"type": "string"},
    "date": {"type": "string", "format": "date-time"},
    "channel": {"enum": ["stable", "beta"], "default": "stable"},
    "min_schema_version": {"type": "string"},
    "supported_arch": {
      "type": "array",
      "items": {"enum": ["mipsel", "mips", "aarch64"]},
      "description": "Step 409"
    },
    "min_requirements": {
      "type": "object",
      "properties": {
        "ram_mb": {"type": "integer"},
        "disk_mb": {"type": "integer"},
        "entware_required": {"type": "boolean"}
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "sha256"],
        "properties": {
          "file": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size": {"type": "integer", "minimum": 0},
          "arch": {"enum": ["mipsel", "mips", "aarch64", "universal"]},
          "type": {"enum": ["runtime", "webui", "schemas", "policies", "bundle"]}
        }
      }
    }
  }
}
