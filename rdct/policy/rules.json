{
  "rules_version": "1.0.0",
  "rules": [
    {
      "id": "A-01",
      "group": "A",
      "trigger_text_ru": "обнаружено свободное место < минимального порога.",
      "action_text_ru": "остановить тяжёлые collectors (mirror, web snapshots), включить ultra-lite режим, сформировать warning, предложить смену USB/очистку.",
      "gate_text": "всегда.",
      "signal": "system.usb_free_bytes",
      "operator": "<",
      "threshold": 52428800,
      "actions": [
        "disable_collector:mvp-15-mirror",
        "disable_collector:ext-web-snapshot",
        "set:performance_mode=lite"
      ],
      "risk": "low",
      "requires_root": false
    },
    {
      "id": "A-02",
      "group": "A",
      "trigger_text_ru": "RAM available < порога.",
      "action_text_ru": "снизить concurrency, отключить тяжёлые collectors, включить backoff.",
      "gate_text": "всегда.",
      "signal": "system.mem_available_bytes",
      "operator": "<",
      "threshold": 33554432,
      "actions": [
        "set:limits.max_concurrency=1",
        "disable_collector:mvp-15-mirror"
      ],
      "risk": "low",
      "requires_root": false
    },
    {
      "id": "A-03",
      "group": "A",
      "trigger_text_ru": "CPU loadavg выше порога длительно.",
      "action_text_ru": "снизить параллелизм, увеличить паузы, предложить Lite режим.",
      "gate_text": "всегда.",
      "signal": "system.loadavg_1m",
      "operator": ">",
      "threshold": 2.0,
      "actions": [
        "set:limits.max_concurrency=1",
        "set:performance_mode=lite"
      ],
      "risk": "low",
      "requires_root": false
    },
    {
      "id": "A-04",
      "group": "A",
      "trigger_text_ru": "обнаружены ошибки FS в dmesg.",
      "action_text_ru": "собрать расширенный storage diagnostic (mount flags, last errors, df, fs type), пометить critical finding.",
      "gate_text": "Medium+.",
      "signal": "system.fs_errors_in_dmesg",
      "operator": "==",
      "threshold": true,
      "actions": [
        "suggest:run_storage_extended"
      ],
      "risk": "medium",
      "requires_root": false
    },
    {
      "id": "A-05",
      "group": "A",
      "trigger_text_ru": "обнаружен OOM killer / признаки OOM.",
      "action_text_ru": "собрать расширенные метрики памяти, список top процессов по RSS/CPU, логи вокруг события, status сервисов.",
      "gate_text": "Medium+.",
      "signal": "system.oom_in_dmesg",
      "operator": "==",
      "threshold": true,
      "actions": [
        "suggest:collect_memory_extended"
      ],
      "risk": "medium",
      "requires_root": false
    },
    {
      "id": "A-06",
      "group": "A",
      "trigger_text_ru": "обнаружен частый reboot/uptime малый.",
      "action_text_ru": "собрать последние логи загрузки, причины, последние ошибки ndm/dmesg.",
      "gate_text": "Medium+.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "A-07",
      "group": "A",
      "trigger_text_ru": "отсутствует /opt но entware ожидается.",
      "action_text_ru": "собрать диагностику монтирования USB, подсказать в UI причины, пометить partial.",
      "gate_text": "всегда.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "A-08",
      "group": "A",
      "trigger_text_ru": "opkg present, но пакеты “сломаны” (ошибки статуса).",
      "action_text_ru": "собрать opkg status, repos, списки, конфликтующие пакеты.",
      "gate_text": "Medium+.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "A-09",
      "group": "A",
      "trigger_text_ru": "отсутствуют важные утилиты для выбранных collectors.",
      "action_text_ru": "если auto-install enabled и сеть доступна — установить зависимости; иначе — пометить недоступность и пропуск.",
      "gate_text": "всегда.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-01",
      "group": "B",
      "trigger_text_ru": "сеть недоступна при попытке auto-install.",
      "action_text_ru": "fallback в offline, отключить функции, требующие зависимости, сформировать уведомление.",
      "gate_text": "всегда.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-02",
      "group": "B",
      "trigger_text_ru": "найден новый listening port по сравнению с индексом.",
      "action_text_ru": "собрать port→pid map, бинарь+hash, конфиг кандидаты, логи кандидаты, web probe (если HTTP).",
      "gate_text": "Medium+ (web probe в Light запрещён).",
      "signal": "diff.new_listening_ports_count",
      "operator": ">",
      "threshold": 0,
      "actions": [
        "run_collector:mvp-13-web-discovery"
      ],
      "risk": "medium",
      "requires_root": false
    },
    {
      "id": "B-03",
      "group": "B",
      "trigger_text_ru": "найден процесс без соответствия пакету (неизвестный бинарь).",
      "action_text_ru": "собрать бинарь метаданные, sha256, mtime, права, parent chain, open files (если доступно), предупреждение.",
      "gate_text": "Full/Extreme для deep; Medium для базового.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-04",
      "group": "B",
      "trigger_text_ru": "процесс потребляет много CPU.",
      "action_text_ru": "собрать топ-вывод top/ps snapshots чаще, собрать логи процесса, проверить связанный сервис.",
      "gate_text": "Medium+.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-05",
      "group": "B",
      "trigger_text_ru": "процесс часто перезапускается (по логам/init).",
      "action_text_ru": "собрать init.d status, последние N строк логов, dmesg вокруг рестартов, конфиг.",
      "gate_text": "Medium+.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-06",
      "group": "B",
      "trigger_text_ru": "найден сервис на нестандартном порту, отвечающий HTTP.",
      "action_text_ru": "сохранить headers, HTML, title, favicon hash, список ссылок, js patterns.",
      "gate_text": "Medium+.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-07",
      "group": "B",
