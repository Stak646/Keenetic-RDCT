      "action_text_ru": "сохранить URL pattern и происхождение (JS file), не подключаться, только документировать.",
      "gate_text": "Medium+.",
      "signal": null,
      "operator": null,
      "threshold": null,
      "actions": [],
      "risk": "unknown",
      "requires_root": false
    },
    {
      "id": "B-08",
      "group": "B",
